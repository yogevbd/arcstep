  .session-clip > i { position: absolute; left: 9px; right: 9px; bottom: 9px; height: 12px; opacity: .6; background: repeating-linear-gradient(90deg, var(--track) 0 2px, transparent 2px 5px); clip-path: polygon(0 65%,7% 30%,14% 78%,21% 10%,28% 60%,35% 30%,42% 85%,49% 40%,56% 60%,63% 15%,70% 80%,77% 45%,84% 65%,91% 25%,100% 70%,100% 100%,0 100%); }
