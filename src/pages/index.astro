  .session-view { min-width: 1100px; min-height: 100%; display: none; grid-template-columns: 92px repeat(6, minmax(150px, 1fr)); grid-template-rows: 48px repeat(4, 74px) 34px; gap: 1px; padding: 8px; background: #292b27; }
