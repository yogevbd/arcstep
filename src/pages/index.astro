---
import Layout from '../layouts/Layout.astro';

const tracks = [
  { name: 'PUNCH DRUMS', type: 'Drum Rack', color: '#ff6b4a', clips: [{ start: 0, length: 4, label: 'NEON KIT / INTRO' }, { start: 4, length: 4, label: 'NEON KIT / DRIVE' }, { start: 8, length: 4, label: 'NEON KIT / BREAK' }, { start: 12, length: 4, label: 'NEON KIT / PEAK' }] },
  { name: 'SUB SIGNAL', type: 'Mono Bass', color: '#f4ce55', clips: [{ start: 0, length: 4, label: 'LOW MOTION' }, { start: 4, length: 4, label: 'LOW MOTION +' }, { start: 9, length: 3, label: 'SUB SPACE' }, { start: 12, length: 4, label: 'LOW MOTION / OCT' }] },
  { name: 'GLASS KEYS', type: 'Poly Synth', color: '#67d4ae', clips: [{ start: 0, length: 8, label: 'GLASS CHORDS' }, { start: 8, length: 4, label: 'GLASS / FILTERED' }, { start: 12, length: 4, label: 'GLASS / OPEN' }] },
  { name: 'AIR CHOP', type: 'Vocal Texture', color: '#72a8ff', clips: [{ start: 1, length: 1, label: 'AH_04' }, { start: 3, length: 1, label: 'AH_07' }, { start: 6, length: 2, label: 'AIR PHRASE' }, { start: 10, length: 2, label: 'AH / REVERSE' }, { start: 14, length: 2, label: 'AIR PHRASE +' }] },
  { name: 'GHOST PERC', type: 'Texture Rack', color: '#e46faf', clips: [{ start: 2, length: 2, label: 'METAL GHOSTS' }, { start: 4, length: 4, label: 'GHOST SHUFFLE' }, { start: 8, length: 4, label: 'DUST LOOP' }, { start: 12, length: 4, label: 'GHOST SHUFFLE +' }] },
  { name: 'NIGHT LEAD', type: 'Wavetable', color: '#a98cff', clips: [{ start: 6, length: 2, label: 'SIGNAL TEASE' }, { start: 8, length: 4, label: 'NIGHT CALL' }, { start: 12, length: 4, label: 'NIGHT CALL / HIGH' }] },
];

const pianoNotes = [
  { note: 'C4', start: 0, length: 3 }, { note: 'G4', start: 0, length: 2 }, { note: 'D#4', start: 3, length: 3 },
  { note: 'A#4', start: 4, length: 2 }, { note: 'F4', start: 6, length: 3 }, { note: 'C5', start: 8, length: 2 },
  { note: 'G4', start: 10, length: 3 }, { note: 'D#4', start: 13, length: 3 },
];

const librarySounds = [
  { name: 'Glass Keys', type: 'Poly Synth', category: 'instruments', color: '#67d4ae' },
  { name: 'Deep Current', type: 'Mono Bass', category: 'instruments', color: '#f4ce55' },
  { name: 'Night Call', type: 'Wavetable', category: 'instruments', color: '#a98cff' },
  { name: 'Neon Kit', type: 'Drum Rack', category: 'drums', color: '#ff6b4a' },
  { name: 'Ghost Perc', type: 'Drum Rack', category: 'drums', color: '#e46faf' },
  { name: 'Transit Hats', type: 'Drum Rack', category: 'drums', color: '#f4ce55' },
  { name: 'Blue Air', type: 'Sampler', category: 'samples', color: '#72a8ff' },
  { name: 'Signal Vox', type: 'Sampler', category: 'samples', color: '#e46faf' },
  { name: 'Platform Noise', type: 'Sampler', category: 'samples', color: '#67d4ae' },
  { name: 'Prism Delay', type: 'Audio Effect', category: 'effects', color: '#72a8ff' },
  { name: 'Wide Chamber', type: 'Audio Effect', category: 'effects', color: '#a98cff' },
  { name: 'Low Pass Motion', type: 'Audio Effect', category: 'effects', color: '#ff6b4a' },
];
---
<Layout title="ARCSTEP — Music Editor">
  <div class="studio" data-studio>
    <header class="app-header">
      <div class="brand-block">
        <a class="brand" href="/" aria-label="Arcstep home">
          <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          <span class="wordmark">ARC<span>/</span>STEP</span>
        </a>
        <span class="project-name" data-project-title>NIGHT TRANSIT <b>•</b> DEMO</span>
      </div>
      <nav class="app-nav" aria-label="Workspace">
        <button class="active" type="button" data-app-view="studio">STUDIO</button>
        <button type="button" data-app-view="projects">PROJECTS</button>
        <button type="button" data-app-view="journal">JOURNAL</button>
        <button type="button" data-app-view="plans">PLANS</button>
      </nav>
      <div class="header-actions">
        <button class="icon-button" type="button" title="Undo" aria-label="Undo" data-undo disabled>↶</button>
        <button class="icon-button" type="button" title="Redo" aria-label="Redo" data-redo disabled>↷</button>
        <span class="save-status" data-save-status><i></i> READY</span>
        <button class="save-button" type="button" data-save-project>SAVE</button>
        <button class="share-button" type="button" data-share>SHARE</button>
        <a class="avatar" href="#" title="Sign in" aria-label="Sign in" data-account data-login>IN</a>
      </div>
    </header>

    <section class="transport" aria-label="Transport controls">
      <div class="transport-left">
        <button class="icon-button" type="button" title="Return to start" aria-label="Return to start" data-restart>↤</button>
        <button class="play-button" type="button" title="Play (Space)" aria-label="Play" data-play><span data-play-icon>▶</span></button>
        <button class="icon-button stop-button" type="button" title="Stop" aria-label="Stop" data-stop>■</button>
        <button class="record-button" type="button" title="Record" aria-label="Record" data-record><span></span></button>
      </div>
      <div class="time-display" aria-live="off">
        <strong data-position>1.1.1</strong>
        <span>POSITION</span>
      </div>
      <label class="tempo-control">
        <span>TEMPO</span>
        <input type="number" min="80" max="160" step="1" value="128" data-tempo />
        <b>BPM</b>
      </label>
      <button class="meter-control" type="button" data-metronome aria-pressed="false"><span>4 / 4</span><small>METRONOME</small></button>
      <div class="transport-spacer"></div>
      <label class="master-volume">
        <span>MASTER</span>
        <input type="range" min="0" max="100" value="78" data-master />
      </label>
      <div class="master-meter" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
      <button class="icon-button" type="button" title="Settings" aria-label="Settings" data-settings>⚙</button>
    </section>

    <div class="workspace">
      <aside class="browser" aria-label="Sound browser">
        <div class="panel-title">
          <span>BROWSER</span>
          <button class="icon-button tiny" type="button" title="Close browser" aria-label="Close browser" data-browser-toggle>×</button>
        </div>
        <label class="search-box"><span aria-hidden="true">⌕</span><input type="search" placeholder="Search sounds" aria-label="Search sounds" data-sound-search /></label>
        <nav class="library-nav" aria-label="Library">
          <button class="active" type="button" data-library="instruments"><span>▦</span> Instruments <b>03</b></button>
          <button type="button" data-library="drums"><span>◫</span> Drums <b>03</b></button>
          <button type="button" data-library="samples"><span>〽</span> Samples <b>03</b></button>
          <button type="button" data-library="effects"><span>⌁</span> Effects <b>03</b></button>
        </nav>
        <div class="sound-list">
          <p data-sound-heading>INSTRUMENTS</p>
          {librarySounds.map(sound => (
            <button type="button" data-sound={sound.name} data-sound-type={sound.type} data-sound-category={sound.category} data-sound-color={sound.color} hidden={sound.category !== 'instruments'}>
              <i style={`--swatch:${sound.color}`}></i><span>{sound.name}<small>{sound.type.toUpperCase()}</small></span><b>＋</b>
            </button>
          ))}
        </div>
        <button class="new-track" type="button" data-new-track>＋ NEW TRACK</button>
      </aside>

      <main class="arrangement" aria-label="Arrangement editor">
        <div class="arrangement-tools">
          <div class="view-switch" aria-label="Editor view">
            <button class="active" type="button" data-view="arrangement">ARRANGE</button>
            <button type="button" data-view="session">SESSION</button>
          </div>
          <button class="tool active" type="button" title="Pointer tool" aria-label="Pointer tool" data-tool="pointer">↖</button>
          <button class="tool" type="button" title="Draw tool" aria-label="Draw tool" data-tool="draw">✎</button>
          <button class="tool" type="button" title="Split tool" aria-label="Split tool" data-tool="split">✂</button>
          <span class="tool-divider"></span>
          <button class="automation-button" type="button" data-automation aria-pressed="false">AUTOMATION</button>
          <button class="snap-control" type="button" data-snap aria-pressed="true"><span>⌗</span> 1/16 <b>⌄</b></button>
          <div class="zoom-control"><button type="button" aria-label="Zoom out" data-zoom-out>−</button><span data-zoom-label>100%</span><button type="button" aria-label="Zoom in" data-zoom-in>＋</button></div>
          <div class="arrangement-label"><span>ARRANGEMENT</span><b>16 BARS • LOOP ON</b></div>
        </div>

        <div class="timeline-scroll" data-timeline-scroll>
          <div class="timeline" data-timeline>
            <div class="ruler-corner"><span>TRACKS</span></div>
            <div class="ruler" data-ruler>
              {Array.from({ length: 16 }, (_, i) => <button type="button" data-bar={i}>{i + 1}</button>)}
              <div class="loop-brace"><i></i><span></span><b></b></div>
            </div>

            {tracks.map((track, trackIndex) => (
              <>
                <section class="track-head" style={`--track:${track.color}`} data-track-head={trackIndex}>
                  <button class="track-color" type="button" title={`Select ${track.name}`} aria-label={`Select ${track.name}`} data-select-track={trackIndex}></button>
                  <div class="track-name"><strong>{track.name}</strong><span>{track.type}</span></div>
                  <div class="track-buttons">
                    <button type="button" title="Mute" aria-label={`Mute ${track.name}`} data-mute={trackIndex}>M</button>
                    <button type="button" title="Solo" aria-label={`Solo ${track.name}`} data-solo={trackIndex}>S</button>
                  </div>
                  <label class="track-volume" title="Track volume"><span>−</span><input type="range" min="0" max="100" value={trackIndex === 0 ? 82 : trackIndex === 1 ? 72 : 64} data-track-volume={trackIndex} /><span>＋</span></label>
                  <i class="track-meter" aria-hidden="true"><b data-track-meter={trackIndex}></b></i>
                </section>
                <div class="track-lane" style={`--track:${track.color}`} data-track-lane={trackIndex}>
                  {track.clips.map((clip, clipIndex) => (
                    <button
                      type="button"
                      class="clip"
                      style={`--start:${clip.start};--length:${clip.length}`}
                      data-clip={`${trackIndex}-${clipIndex}`}
                      data-track={trackIndex}
                      aria-label={`${clip.label}, bars ${clip.start + 1} to ${clip.start + clip.length + 1}`}
                    >
                      <span>{clip.label}</span>
                      <canvas width="240" height="50" data-wave={trackIndex} aria-hidden="true"></canvas>
                      <i class="clip-resize" data-resize-clip aria-hidden="true"></i>
                    </button>
                  ))}
                </div>
              </>
            ))}
            <div class="playhead" data-playhead><span></span></div>
          </div>
          <div class="session-view" data-session-view>
            <div class="session-corner"><span>SCENES</span><small>LIVE SET</small></div>
            {tracks.map((track) => (
              <div class="session-track-title" style={`--track:${track.color}`}>
                <i></i><span>{track.name}<small>{track.type}</small></span>
              </div>
            ))}
            {[0, 1, 2, 3].map((scene) => (
              <>
                <button class="scene-launch" type="button" data-scene={scene}><span>{scene + 1}</span>▶</button>
                {tracks.map((track, trackIndex) => (
                  <button
                    class={`session-clip ${scene === 2 && trackIndex === 3 ? 'empty' : ''}`}
                    type="button"
                    style={`--track:${track.color}`}
                    data-session-clip
                    data-track={trackIndex}
                  >
                    {scene === 2 && trackIndex === 3 ? <span>＋</span> : <><span>{track.clips[scene % track.clips.length]?.label}</span><i></i><b>▶</b></>}
                  </button>
                ))}
              </>
            ))}
            <div class="session-corner stop-row"><span>STOP</span></div>
            {tracks.map((_, index) => <button class="track-stop" type="button" data-track-stop={index}>■</button>)}
          </div>
        </div>
      </main>
    </div>

    <section class="editor-panel" data-editor style="--selected:#67d4ae">
      <div class="editor-tabs">
        <button class="active" type="button" data-editor-tab="clip">CLIP</button>
        <button type="button" data-editor-tab="device">DEVICE</button>
        <span data-selected-label>GLASS KEYS / GLASS CHORDS</span>
        <button class="inspector-command" type="button" title="Rename selected track or clip" data-rename-selected>✎ RENAME</button>
        <button class="inspector-command" type="button" title="Add clip to selected track" data-add-clip>＋ CLIP</button>
        <button class="inspector-command danger" type="button" title="Delete selected clip, or the selected track when no clip is selected" data-delete-selected>× DELETE</button>
        <button class="icon-button tiny" type="button" title="Collapse editor" aria-label="Collapse editor" data-editor-toggle>⌄</button>
      </div>
      <div class="clip-editor">
        <div class="piano-labels clip-content" aria-hidden="true"><span>C5</span><span>A#4</span><span>G4</span><span>F4</span><span>D#4</span><span>C4</span></div>
        <div class="piano-roll clip-content" data-piano-roll title="Click to add a note; double-click a note to delete it">
          {pianoNotes.map(note => <i style={`--note:${note.note};--start:${note.start};--length:${note.length}`}></i>)}
        </div>
        <div class="device-controls">
          <label><span>CUTOFF</span><input type="range" min="120" max="12000" value="5200" data-cutoff /><b data-cutoff-value>5.2 kHz</b></label>
          <label><span>RESONANCE</span><input type="range" min="0" max="18" value="3" data-resonance /><b data-resonance-value>3%</b></label>
          <label><span>REVERB</span><input type="range" min="0" max="100" value="28" data-reverb /><b data-reverb-value>28%</b></label>
          <div class="device-name"><i></i><span>GLASS KEYS<b>POLY SYNTH • ACTIVE</b></span></div>
        </div>
      </div>
    </section>

    <section class="app-view-panel projects-panel" data-panel="projects" aria-label="Saved projects" hidden>
      <header class="view-header">
        <div>
          <span>MEMBER LIBRARY</span>
          <h1>Projects</h1>
          <p data-project-subtitle>Your ARCSTEP sessions, synced through Wix.</p>
        </div>
        <div class="view-actions">
          <button type="button" data-new-project>＋ NEW</button>
          <button class="primary" type="button" data-save-project>SAVE CURRENT</button>
        </div>
      </header>
      <div class="member-strip" data-member-strip>
        <div class="member-avatar" data-member-avatar>AS</div>
        <div><strong data-member-name>GUEST PRODUCER</strong><span data-member-state>Sign in to sync projects across devices.</span></div>
        <a class="member-action" href="#" data-member-action data-login>SIGN IN</a>
      </div>
      <div class="project-metrics" aria-label="Project statistics">
        <span><b data-project-count>0</b> PROJECTS</span>
        <span><b>16</b> BAR DEMO</span>
        <span><b>128</b> DEFAULT BPM</span>
        <span><b>48 kHz</b> ENGINE</span>
      </div>
      <div class="project-grid" data-project-grid>
        <div class="empty-state" data-project-empty>
          <i class="brand-mark" aria-hidden="true"><i></i><i></i><i></i><i></i></i>
          <strong>NO SAVED PROJECTS YET</strong>
          <span>Save NIGHT TRANSIT to start your member library.</span>
        </div>
      </div>
    </section>

    <section class="app-view-panel journal-panel" data-panel="journal" aria-label="Arcstep journal" hidden>
      <header class="view-header journal-header">
        <div>
          <span>ARCSTEP FIELD NOTES</span>
          <h1>Journal</h1>
          <p>Arrangement, low-end, and groove systems for finishing records.</p>
        </div>
        <div class="journal-signal"><i></i><i></i><i></i><i></i><i></i><span>WIX BLOG / LIVE</span></div>
      </header>
      <div class="journal-layout">
        <nav class="post-list" data-post-list aria-label="Journal posts">
          <div class="loading-row"><i></i><span>LOADING FIELD NOTES</span></div>
        </nav>
        <article class="post-reader" data-post-reader>
          <span class="post-kicker">SELECT A FIELD NOTE</span>
          <h2>Ideas that survive the speakers.</h2>
          <p>ARCSTEP Journal connects production decisions to the session in front of you.</p>
        </article>
      </div>
    </section>

    <section class="app-view-panel plans-panel" data-panel="plans" aria-label="Arcstep subscription plans" hidden>
      <header class="view-header plans-header">
        <div>
          <span>ARCSTEP ACCESS</span>
          <h1>Plans</h1>
          <p>More cloud sessions, lossless exports, stems, and collaborative rooms.</p>
        </div>
        <span class="current-plan" data-current-plan>CURRENT / FREE</span>
      </header>
      <div class="plans-intro">
        <strong>MAKE THE IDEA.<br />KEEP THE MOMENTUM.</strong>
        <p>Every plan includes the six-track NIGHT TRANSIT session, the full browser instrument engine, and unlimited local edits.</p>
      </div>
      <div class="plan-grid" data-plan-grid>
        <article class="plan-card free-plan">
          <span>START</span><h2>Free</h2><p><b>$0</b> forever</p>
          <ul><li>3 cloud projects</li><li>Unlimited local tracks</li><li>Standard audio export</li><li>ARCSTEP Journal</li></ul>
          <button type="button" disabled>CURRENT PLAN</button>
        </article>
        <div class="loading-row plan-loading"><i></i><span>LOADING WIX PLANS</span></div>
      </div>
      <footer class="plans-footnote"><span>SECURE CHECKOUT BY WIX</span><span>CANCEL RECURRING PLANS ANYTIME</span><span>MEMBER ACCOUNT REQUIRED</span></footer>
    </section>

    <dialog class="track-dialog" data-track-dialog>
      <form method="dialog" data-track-form>
        <header><span>TRACK SETUP</span><button type="button" aria-label="Close" title="Close" data-close-track>×</button></header>
        <label><span>TRACK NAME</span><input name="trackName" value="NEW SIGNAL" maxlength="24" required /></label>
        <fieldset>
          <legend>INSTRUMENT</legend>
          <label><input type="radio" name="trackType" value="Wavetable" checked /><span>WAVETABLE<small>POLY SYNTH</small></span></label>
          <label><input type="radio" name="trackType" value="Drum Rack" /><span>DRUM RACK<small>16-PAD KIT</small></span></label>
          <label><input type="radio" name="trackType" value="Mono Bass" /><span>MONO BASS<small>SUB / GLIDE</small></span></label>
          <label><input type="radio" name="trackType" value="Sampler" /><span>SAMPLER<small>ONE SHOT</small></span></label>
        </fieldset>
        <fieldset class="color-fieldset">
          <legend>TRACK COLOR</legend>
          {['#67d4ae', '#72a8ff', '#a98cff', '#e46faf', '#ff6b4a', '#f4ce55'].map((color, index) => (
            <label style={`--choice:${color}`}><input type="radio" name="trackColor" value={color} checked={index === 0} /><i></i></label>
          ))}
        </fieldset>
        <footer><button type="button" data-close-track>CANCEL</button><button class="primary" type="submit">CREATE TRACK</button></footer>
      </form>
    </dialog>

    <dialog class="track-dialog settings-dialog" data-settings-dialog>
      <form method="dialog" data-settings-form>
        <header><span>STUDIO SETTINGS</span><button type="button" aria-label="Close" title="Close" data-close-settings>×</button></header>
        <label><span>AUDIO SAMPLE RATE</span><select name="sampleRate" data-sample-rate><option value="44100">44.1 kHz</option><option value="48000" selected>48 kHz</option></select></label>
        <label class="toggle-setting"><span>LOOP PLAYBACK</span><input type="checkbox" name="loopPlayback" data-loop-playback checked /></label>
        <label class="toggle-setting"><span>AUTOSAVE LOCAL DRAFT</span><input type="checkbox" name="autosave" data-autosave checked /></label>
        <div class="settings-actions"><button type="button" data-export-project>EXPORT SESSION</button><button type="button" data-reset-demo>RESET DEMO</button></div>
        <footer><button type="button" data-close-settings>CANCEL</button><button class="primary" type="submit">APPLY</button></footer>
      </form>
    </dialog>

    <div class="status-bar">
      <button type="button" data-browser-toggle>☰ <span>BROWSER</span></button>
      <span class="cpu">CPU <i><b data-cpu></b></i> <em data-cpu-label>08%</em></span>
      <span class="hint">SPACE TO PLAY • CLICK TIMELINE TO SEEK</span>
      <span data-audio-rate>48 kHz</span>
    </div>
    <div class="toast" role="status" aria-live="polite" data-toast-box></div>
  </div>

  <script>
    import '../scripts/studio.ts';
  </script>
</Layout>

<style is:global>
  * { box-sizing: border-box; }
  html { background: #111211; }
  body { margin: 0; overflow: hidden; background: #111211; color: #ecece7; font-family: 'Manrope', sans-serif; }
  button, input, select { font: inherit; }
  button { color: inherit; }
  button:focus-visible, input:focus-visible { outline: 2px solid #f4ce55; outline-offset: 2px; }
  .studio { --header: 58px; --transport: 70px; --status: 28px; --editor: 212px; --browser: 224px; min-width: 320px; height: 100dvh; display: grid; grid-template-rows: var(--header) var(--transport) minmax(240px, 1fr) var(--editor) var(--status); background: #151614; overflow: hidden; }
  button { border: 0; background: none; padding: 0; cursor: pointer; }
  .app-header { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 0 14px 0 17px; background: #0c0d0c; border-bottom: 1px solid #2b2d29; }
  .brand-block, .brand, .header-actions, .transport, .transport-left { display: flex; align-items: center; }
  .brand { gap: 11px; color: #f7f7f2; font-weight: 700; font-size: 16px; letter-spacing: 0.1em; text-decoration: none; }
  .wordmark > span { color: #ff6b4a; }
  .brand-mark { width: 23px; height: 24px; display: flex; align-items: center; justify-content: center; gap: 2px; border: 1px solid #596057; background: #151714; }
  .brand-mark i { display: block; width: 2px; background: #67d4ae; }
  .brand-mark i:nth-child(1) { height: 6px; } .brand-mark i:nth-child(2) { height: 14px; } .brand-mark i:nth-child(3) { height: 10px; } .brand-mark i:nth-child(4) { height: 4px; }
  .project-name { margin-left: 22px; padding: 7px 0 7px 22px; border-left: 1px solid #343631; font: 500 11px 'DM Mono', monospace; letter-spacing: .04em; color: #b5b8b0; white-space: nowrap; }
  .project-name b { color: #67d4ae; }
  .app-nav { align-self: stretch; display: flex; align-items: stretch; margin-left: auto; }
  .app-nav button { min-width: 78px; padding: 0 11px; border-bottom: 2px solid transparent; color: #7d8179; font: 500 9px 'DM Mono', monospace; letter-spacing: .04em; }
  .app-nav button:hover { color: #d8dad3; background: #151714; }
  .app-nav button.active { color: #f2f2ed; border-bottom-color: #67d4ae; }
  .header-actions { gap: 6px; }
  .icon-button { width: 32px; height: 32px; display: inline-grid; place-items: center; border: 1px solid transparent; color: #a8aba3; font-size: 17px; }
