  .track-lane { position: relative; min-height: 72px; border-bottom: 1px solid #2e302b; background-image: repeating-linear-gradient(to right, transparent 0, transparent 23px, #22241f 24px), repeating-linear-gradient(to right, transparent 0, transparent 95px, #363932 96px); }
  .automation-on .track-lane::after { content: ''; position: absolute; z-index: 4; left: 0; right: 0; top: 54%; height: 14px; pointer-events: none; background: var(--track); opacity: .8; clip-path: polygon(0 45%,13% 45%,25% 100%,42% 30%,61% 70%,78% 10%,100% 50%,100% 58%,78% 18%,61% 78%,42% 38%,25% 100%,13% 53%,0 53%); }
  .clip { --gap: 3px; position: absolute; left: calc(var(--start) * 6.25% + var(--gap)); top: 7px; width: calc(var(--length) * 6.25% - var(--gap) * 2); min-width: 14px; height: calc(100% - 14px); overflow: hidden; border: 1px solid color-mix(in srgb, var(--track) 72%, #111); background: color-mix(in srgb, var(--track) 14%, #161714); text-align: left; }
