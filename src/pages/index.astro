---
import Layout from '../layouts/Layout.astro';

const tracks = [
  { name: 'PUNCH DRUMS', type: 'Drum Rack', color: '#ff6b4a', clips: [{ start: 0, length: 4, label: 'NEON KIT' }, { start: 4, length: 4, label: 'NEON KIT / B' }] },
  { name: 'SUB SIGNAL', type: 'Mono Bass', color: '#f4ce55', clips: [{ start: 0, length: 2, label: 'LOW MOTION' }, { start: 2, length: 2, label: 'LOW MOTION' }, { start: 4, length: 4, label: 'LOW MOTION +' }] },
  { name: 'GLASS KEYS', type: 'Poly Synth', color: '#67d4ae', clips: [{ start: 0, length: 4, label: 'GLASS CHORDS' }, { start: 4, length: 4, label: 'GLASS CHORDS' }] },
  { name: 'AIR CHOP', type: 'Vocal Texture', color: '#72a8ff', clips: [{ start: 1, length: 1, label: 'AH_04' }, { start: 3, length: 1, label: 'AH_04' }, { start: 5, length: 1, label: 'AH_07' }, { start: 7, length: 1, label: 'AH_04' }] },
];

const pianoNotes = [
  { note: 'C4', start: 0, length: 3 }, { note: 'G4', start: 0, length: 2 }, { note: 'D#4', start: 3, length: 3 },
  { note: 'A#4', start: 4, length: 2 }, { note: 'F4', start: 6, length: 3 }, { note: 'C5', start: 8, length: 2 },
  { note: 'G4', start: 10, length: 3 }, { note: 'D#4', start: 13, length: 3 },
];
---
<Layout title="ARCSTEP — Music Editor">
  <div class="studio" data-studio>
    <header class="app-header">
      <div class="brand-block">
        <a class="brand" href="/" aria-label="Arcstep home">
          <span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          <span class="wordmark">ARC<span>/</span>STEP</span>
        </a>
        <span class="project-name">NIGHT TRANSIT <b>•</b> DEMO</span>
      </div>
      <div class="header-actions">
        <button class="icon-button" type="button" title="Undo" aria-label="Undo" data-toast="Nothing to undo">↶</button>
        <button class="icon-button" type="button" title="Redo" aria-label="Redo" data-toast="Nothing to redo">↷</button>
        <span class="save-status"><i></i> SAVED</span>
        <button class="share-button" type="button" data-toast="Share link copied">SHARE</button>
        <button class="avatar" type="button" title="Account" aria-label="Open account menu">YB</button>
      </div>
    </header>

    <section class="transport" aria-label="Transport controls">
      <div class="transport-left">
        <button class="icon-button" type="button" title="Return to start" aria-label="Return to start" data-restart>↤</button>
        <button class="play-button" type="button" title="Play (Space)" aria-label="Play" data-play><span data-play-icon>▶</span></button>
        <button class="icon-button stop-button" type="button" title="Stop" aria-label="Stop" data-stop>■</button>
        <button class="record-button" type="button" title="Record" aria-label="Record" data-record><span></span></button>
      </div>
      <div class="time-display" aria-live="off">
        <strong data-position>1.1.1</strong>
        <span>POSITION</span>
      </div>
      <label class="tempo-control">
        <span>TEMPO</span>
        <input type="number" min="80" max="160" step="1" value="128" data-tempo />
        <b>BPM</b>
      </label>
      <button class="meter-control" type="button" data-metronome aria-pressed="false"><span>4 / 4</span><small>METRONOME</small></button>
      <div class="transport-spacer"></div>
      <label class="master-volume">
        <span>MASTER</span>
        <input type="range" min="0" max="100" value="78" data-master />
      </label>
      <div class="master-meter" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
      <button class="icon-button" type="button" title="Settings" aria-label="Settings" data-toast="Studio settings ready">⚙</button>
    </section>

    <div class="workspace">
      <aside class="browser" aria-label="Sound browser">
        <div class="panel-title">
          <span>BROWSER</span>
          <button class="icon-button tiny" type="button" title="Close browser" aria-label="Close browser" data-browser-toggle>×</button>
        </div>
        <label class="search-box"><span aria-hidden="true">⌕</span><input type="search" placeholder="Search sounds" aria-label="Search sounds" /></label>
        <nav class="library-nav" aria-label="Library">
          <button class="active" type="button"><span>▦</span> Instruments <b>12</b></button>
          <button type="button"><span>◫</span> Drums <b>24</b></button>
          <button type="button"><span>〽</span> Samples <b>48</b></button>
          <button type="button"><span>⌁</span> Effects <b>16</b></button>
        </nav>
        <div class="sound-list">
          <p>FAVORITES</p>
          <button type="button" data-toast="Glass Keys loaded"><i style="--swatch:#67d4ae"></i><span>Glass Keys<small>POLY SYNTH</small></span><b>＋</b></button>
          <button type="button" data-toast="Deep Current loaded"><i style="--swatch:#f4ce55"></i><span>Deep Current<small>MONO BASS</small></span><b>＋</b></button>
          <button type="button" data-toast="Neon Kit loaded"><i style="--swatch:#ff6b4a"></i><span>Neon Kit<small>DRUM RACK</small></span><b>＋</b></button>
          <button type="button" data-toast="Blue Air loaded"><i style="--swatch:#72a8ff"></i><span>Blue Air<small>TEXTURE</small></span><b>＋</b></button>
        </div>
        <button class="new-track" type="button" data-toast="New track added to queue">＋ NEW TRACK</button>
      </aside>

      <main class="arrangement" aria-label="Arrangement editor">
        <div class="arrangement-tools">
          <div class="view-switch" aria-label="Editor view">
            <button class="active" type="button" data-view="arrangement">ARRANGE</button>
            <button type="button" data-view="session">SESSION</button>
          </div>
          <button class="tool active" type="button" title="Pointer tool" aria-label="Pointer tool">↖</button>
          <button class="tool" type="button" title="Draw tool" aria-label="Draw tool">✎</button>
          <button class="tool" type="button" title="Split tool" aria-label="Split tool">✂</button>
          <span class="tool-divider"></span>
          <button class="automation-button" type="button" data-automation aria-pressed="false">AUTOMATION</button>
          <button class="snap-control" type="button" data-snap aria-pressed="true"><span>⌗</span> 1/16 <b>⌄</b></button>
          <div class="zoom-control"><button type="button" aria-label="Zoom out" data-zoom-out>−</button><span>100%</span><button type="button" aria-label="Zoom in" data-zoom-in>＋</button></div>
          <div class="arrangement-label"><span>ARRANGEMENT</span><b>8 BARS • LOOP ON</b></div>
        </div>

        <div class="timeline-scroll" data-timeline-scroll>
          <div class="timeline" data-timeline>
            <div class="ruler-corner"><span>TRACKS</span></div>
            <div class="ruler" data-ruler>
              {Array.from({ length: 8 }, (_, i) => <button type="button" data-bar={i}>{i + 1}</button>)}
              <div class="loop-brace"><i></i><span></span><b></b></div>
            </div>

            {tracks.map((track, trackIndex) => (
              <>
                <section class="track-head" style={`--track:${track.color}`} data-track-head={trackIndex}>
                  <button class="track-color" type="button" title={`Select ${track.name}`} aria-label={`Select ${track.name}`} data-select-track={trackIndex}></button>
                  <div class="track-name"><strong>{track.name}</strong><span>{track.type}</span></div>
                  <div class="track-buttons">
                    <button type="button" title="Mute" aria-label={`Mute ${track.name}`} data-mute={trackIndex}>M</button>
                    <button type="button" title="Solo" aria-label={`Solo ${track.name}`} data-solo={trackIndex}>S</button>
                  </div>
                  <label class="track-volume" title="Track volume"><span>−</span><input type="range" min="0" max="100" value={trackIndex === 0 ? 82 : trackIndex === 1 ? 72 : 64} data-track-volume={trackIndex} /><span>＋</span></label>
                </section>
                <div class="track-lane" style={`--track:${track.color}`} data-track-lane={trackIndex}>
                  {track.clips.map((clip, clipIndex) => (
                    <button
                      type="button"
                      class="clip"
                      style={`--start:${clip.start};--length:${clip.length}`}
                      data-clip={`${trackIndex}-${clipIndex}`}
                      data-track={trackIndex}
                      aria-label={`${clip.label}, bars ${clip.start + 1} to ${clip.start + clip.length + 1}`}
                    >
                      <span>{clip.label}</span>
                      <canvas width="240" height="50" data-wave={trackIndex} aria-hidden="true"></canvas>
                    </button>
                  ))}
                </div>
              </>
            ))}
            <div class="playhead" data-playhead><span></span></div>
          </div>
          <div class="session-view" data-session-view>
            <div class="session-corner"><span>SCENES</span><small>LIVE SET</small></div>
            {tracks.map((track) => (
              <div class="session-track-title" style={`--track:${track.color}`}>
                <i></i><span>{track.name}<small>{track.type}</small></span>
              </div>
            ))}
            {[0, 1, 2, 3].map((scene) => (
              <>
                <button class="scene-launch" type="button" data-scene={scene}><span>{scene + 1}</span>▶</button>
                {tracks.map((track, trackIndex) => (
                  <button
                    class={`session-clip ${scene === 2 && trackIndex === 3 ? 'empty' : ''}`}
                    type="button"
                    style={`--track:${track.color}`}
                    data-session-clip
                    data-track={trackIndex}
                  >
                    {scene === 2 && trackIndex === 3 ? <span>＋</span> : <><span>{track.clips[scene % track.clips.length]?.label}</span><i></i><b>▶</b></>}
                  </button>
                ))}
              </>
            ))}
            <div class="session-corner stop-row"><span>STOP</span></div>
            {tracks.map((_, index) => <button class="track-stop" type="button" data-track-stop={index}>■</button>)}
          </div>
        </div>
      </main>
    </div>

    <section class="editor-panel" data-editor style="--selected:#67d4ae">
      <div class="editor-tabs">
        <button class="active" type="button" data-editor-tab="clip">CLIP</button>
        <button type="button" data-editor-tab="device">DEVICE</button>
        <span data-selected-label>GLASS KEYS / GLASS CHORDS</span>
        <button class="icon-button tiny" type="button" title="Collapse editor" aria-label="Collapse editor" data-editor-toggle>⌄</button>
      </div>
      <div class="clip-editor">
        <div class="piano-labels clip-content" aria-hidden="true"><span>C5</span><span>A#4</span><span>G4</span><span>F4</span><span>D#4</span><span>C4</span></div>
        <div class="piano-roll clip-content">
          {pianoNotes.map(note => <i style={`--note:${note.note};--start:${note.start};--length:${note.length}`}></i>)}
        </div>
        <div class="device-controls">
          <label><span>CUTOFF</span><input type="range" min="120" max="12000" value="5200" data-cutoff /><b data-cutoff-value>5.2 kHz</b></label>
          <label><span>RESONANCE</span><input type="range" min="0" max="18" value="3" data-resonance /><b data-resonance-value>3%</b></label>
          <label><span>REVERB</span><input type="range" min="0" max="100" value="28" /><b>28%</b></label>
          <div class="device-name"><i></i><span>GLASS KEYS<b>POLY SYNTH • ACTIVE</b></span></div>
        </div>
      </div>
    </section>

    <div class="status-bar">
      <button type="button" data-browser-toggle>☰ <span>BROWSER</span></button>
      <span class="cpu">CPU <i><b data-cpu></b></i> <em data-cpu-label>08%</em></span>
      <span class="hint">SPACE TO PLAY • CLICK TIMELINE TO SEEK</span>
      <span>48 kHz</span>
    </div>
    <div class="toast" role="status" aria-live="polite" data-toast-box></div>
  </div>

  <script>
    const studio = document.querySelector<HTMLElement>('[data-studio]');
    if (studio) {
      const playButton = studio.querySelector<HTMLButtonElement>('[data-play]')!;
      const playIcon = studio.querySelector<HTMLElement>('[data-play-icon]')!;
      const positionLabel = studio.querySelector<HTMLElement>('[data-position]')!;
      const playhead = studio.querySelector<HTMLElement>('[data-playhead]')!;
      const timeline = studio.querySelector<HTMLElement>('[data-timeline]')!;
      const tempoInput = studio.querySelector<HTMLInputElement>('[data-tempo]')!;
      const masterInput = studio.querySelector<HTMLInputElement>('[data-master]')!;
      const cutoffInput = studio.querySelector<HTMLInputElement>('[data-cutoff]')!;
      const resonanceInput = studio.querySelector<HTMLInputElement>('[data-resonance]')!;
      const toastBox = studio.querySelector<HTMLElement>('[data-toast-box]')!;

      let audio: AudioContext | null = null;
      let masterGain: GainNode | null = null;
      let analyser: AnalyserNode | null = null;
      let trackGains: GainNode[] = [];
      let trackFilters: BiquadFilterNode[] = [];
      let noiseBuffer: AudioBuffer | null = null;
      let schedulerId = 0;
      let animationId = 0;
      let playing = false;
      let position = 0;
      let startedAt = 0;
      let nextStep = 0;
      let nextNoteAt = 0;
      let selectedTrack = 2;
      const muted = [false, false, false, false];
      const soloed = [false, false, false, false];
      const volumes = [0.82, 0.72, 0.64, 0.64];
      const meterBars = [...studio.querySelectorAll<HTMLElement>('.master-meter i')];

      const bpm = () => Number(tempoInput.value) || 128;
      const stepDuration = () => 60 / bpm() / 4;
      const loopDuration = () => 8 * 4 * 60 / bpm();

      function showToast(message: string) {
        toastBox.textContent = message;
        toastBox.classList.add('visible');
        window.setTimeout(() => toastBox.classList.remove('visible'), 1800);
      }

      function initAudio() {
        if (audio) return;
        audio = new AudioContext();
        masterGain = audio.createGain();
        analyser = audio.createAnalyser();
        analyser.fftSize = 64;
        masterGain.gain.value = Number(masterInput.value) / 100;
        masterGain.connect(analyser).connect(audio.destination);
        trackGains = volumes.map((volume, index) => {
          const filter = audio!.createBiquadFilter();
          filter.type = 'lowpass';
          filter.frequency.value = index === 0 ? 12000 : index === 1 ? 1800 : 5200;
          trackFilters.push(filter);
          const gain = audio!.createGain();
          gain.gain.value = volume;
          filter.connect(gain).connect(masterGain!);
          return gain;
        });
        noiseBuffer = audio.createBuffer(1, audio.sampleRate, audio.sampleRate);
        const data = noiseBuffer.getChannelData(0);
        for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;
        updateMix();
      }

      function tone(frequency: number, time: number, length: number, destination: AudioNode, type: OscillatorType, level: number, glide = 0) {
        if (!audio) return;
        const oscillator = audio.createOscillator();
        const gain = audio.createGain();
        oscillator.type = type;
        oscillator.frequency.setValueAtTime(frequency, time);
        if (glide) oscillator.frequency.exponentialRampToValueAtTime(glide, time + length);
        gain.gain.setValueAtTime(0.0001, time);
        gain.gain.exponentialRampToValueAtTime(level, time + 0.008);
        gain.gain.exponentialRampToValueAtTime(0.0001, time + length);
        oscillator.connect(gain).connect(destination);
        oscillator.start(time);
        oscillator.stop(time + length + 0.02);
      }

      function noise(time: number, length: number, destination: AudioNode, level: number, frequency: number) {
        if (!audio || !noiseBuffer) return;
        const source = audio.createBufferSource();
        const filter = audio.createBiquadFilter();
        const gain = audio.createGain();
        source.buffer = noiseBuffer;
        filter.type = frequency > 5000 ? 'highpass' : 'bandpass';
        filter.frequency.value = frequency;
        gain.gain.setValueAtTime(level, time);
        gain.gain.exponentialRampToValueAtTime(0.0001, time + length);
        source.connect(filter).connect(gain).connect(destination);
        source.start(time);
        source.stop(time + length);
      }

      function schedule(step: number, time: number) {
        if (!audio) return;
        const within = step % 16;
        const bar = Math.floor(step / 16) % 8;
        if ([0, 4, 8, 11, 12].includes(within)) tone(130, time, 0.18, trackFilters[0], 'sine', 0.9, 45);
        if (within === 4 || within === 12) noise(time, 0.16, trackFilters[0], 0.34, 1800);
        if (within % 2 === 0) noise(time, within % 4 ? 0.025 : 0.04, trackFilters[0], 0.07, 7000);
        const bassPattern = [36, 36, 43, 36, 39, 39, 46, 34];
        if ([0, 3, 6, 8, 11, 14].includes(within)) {
          const midi = bassPattern[bar] + (within === 14 ? 7 : 0);
          tone(440 * Math.pow(2, (midi - 69) / 12), time, stepDuration() * 2.4, trackFilters[1], 'sawtooth', 0.16);
        }
        if (within === 0 || within === 8) {
          const roots = [48, 51, 53, 46, 48, 51, 55, 53];
          const root = roots[bar];
          [0, 3, 7, 10].forEach(interval => tone(440 * Math.pow(2, (root + interval - 69) / 12), time, stepDuration() * 7.5, trackFilters[2], 'triangle', 0.055));
        }
        if ((bar % 2 === 1 && within === 6) || (bar % 2 === 0 && within === 14)) {
          tone(440 * Math.pow(2, ((bar % 3 ? 72 : 75) - 69) / 12), time, 0.22, trackFilters[3], 'sine', 0.1, 660);
        }
      }

      function scheduler() {
        if (!audio || !playing) return;
        while (nextNoteAt < audio.currentTime + 0.1) {
          schedule(nextStep % 128, nextNoteAt);
          nextNoteAt += stepDuration();
          nextStep = (nextStep + 1) % 128;
        }
      }

      function updateMix() {
        const anySolo = soloed.some(Boolean);
        trackGains.forEach((gain, index) => {
          const audible = !muted[index] && (!anySolo || soloed[index]);
          gain.gain.setTargetAtTime(audible ? volumes[index] : 0, audio?.currentTime ?? 0, 0.01);
        });
      }

      function formatPosition(seconds: number) {
        const totalBeats = seconds / (60 / bpm());
        const bar = Math.floor(totalBeats / 4) + 1;
        const beat = Math.floor(totalBeats % 4) + 1;
        const sixteenth = Math.floor((totalBeats % 1) * 4) + 1;
        return `${bar}.${beat}.${sixteenth}`;
      }

      function drawMeters() {
        if (!analyser) return;
        const values = new Uint8Array(analyser.frequencyBinCount);
        analyser.getByteFrequencyData(values);
        const energy = values.reduce((sum, value) => sum + value, 0) / values.length / 255;
        meterBars.forEach((bar, index) => bar.classList.toggle('on', index / meterBars.length < energy * 1.6));
      }

      function animate() {
        if (playing) position = ((performance.now() - startedAt) / 1000) % loopDuration();
        const progress = position / loopDuration();
        playhead.style.setProperty('--progress', String(progress));
        positionLabel.textContent = formatPosition(position);
        drawMeters();
        animationId = requestAnimationFrame(animate);
      }

      async function togglePlay() {
        initAudio();
        await audio!.resume();
        if (playing) {
          playing = false;
          window.clearInterval(schedulerId);
          masterGain!.gain.cancelScheduledValues(audio!.currentTime);
          playButton.classList.remove('playing');
          playIcon.textContent = '▶';
          playButton.setAttribute('aria-label', 'Play');
          return;
        }
        playing = true;
        startedAt = performance.now() - position * 1000;
        nextStep = Math.floor(position / stepDuration()) % 128;
        nextNoteAt = audio!.currentTime + 0.04;
        scheduler();
        schedulerId = window.setInterval(scheduler, 25);
        playButton.classList.add('playing');
        playIcon.textContent = 'Ⅱ';
        playButton.setAttribute('aria-label', 'Pause');
      }

      function stop() {
        playing = false;
        position = 0;
        window.clearInterval(schedulerId);
        playButton.classList.remove('playing');
        playIcon.textContent = '▶';
        playButton.setAttribute('aria-label', 'Play');
      }

      function selectTrack(index: number, clipLabel?: string) {
        selectedTrack = index;
        const colors = ['#ff6b4a', '#f4ce55', '#67d4ae', '#72a8ff'];
        const names = ['PUNCH DRUMS', 'SUB SIGNAL', 'GLASS KEYS', 'AIR CHOP'];
        studio.querySelector<HTMLElement>('[data-editor]')?.style.setProperty('--selected', colors[index]);
        studio.querySelector<HTMLElement>('[data-selected-label]')!.textContent = `${names[index]} / ${clipLabel ?? 'TRACK'}`;
        studio.querySelectorAll('[data-track-head]').forEach((head, i) => head.classList.toggle('selected', i === index));
      }

      playButton.addEventListener('click', togglePlay);
      studio.querySelector('[data-stop]')?.addEventListener('click', stop);
      studio.querySelector('[data-restart]')?.addEventListener('click', () => { position = 0; if (playing) startedAt = performance.now(); });
      studio.querySelector('[data-record]')?.addEventListener('click', (event) => {
        const button = event.currentTarget as HTMLButtonElement;
        button.classList.toggle('armed');
        showToast(button.classList.contains('armed') ? 'Recording armed' : 'Recording disarmed');
      });
      studio.querySelector('[data-metronome]')?.addEventListener('click', (event) => {
        const button = event.currentTarget as HTMLButtonElement;
        const on = button.getAttribute('aria-pressed') !== 'true';
        button.setAttribute('aria-pressed', String(on));
        button.classList.toggle('active', on);
      });
      tempoInput.addEventListener('change', () => {
        tempoInput.value = String(Math.max(80, Math.min(160, Number(tempoInput.value) || 128)));
        if (playing) startedAt = performance.now() - position * 1000;
      });
      masterInput.addEventListener('input', () => {
        if (masterGain && audio) masterGain.gain.setTargetAtTime(Number(masterInput.value) / 100, audio.currentTime, 0.01);
      });
      cutoffInput.addEventListener('input', () => {
        const value = Number(cutoffInput.value);
        studio.querySelector<HTMLElement>('[data-cutoff-value]')!.textContent = value >= 1000 ? `${(value / 1000).toFixed(1)} kHz` : `${value} Hz`;
        if (trackFilters[selectedTrack] && audio) trackFilters[selectedTrack].frequency.setTargetAtTime(value, audio.currentTime, 0.02);
      });
      resonanceInput.addEventListener('input', () => {
        const value = Number(resonanceInput.value);
        studio.querySelector<HTMLElement>('[data-resonance-value]')!.textContent = `${value}%`;
        if (trackFilters[selectedTrack]) trackFilters[selectedTrack].Q.value = value;
      });
      studio.querySelectorAll<HTMLInputElement>('[data-track-volume]').forEach(input => input.addEventListener('input', () => {
        const index = Number(input.dataset.trackVolume);
        volumes[index] = Number(input.value) / 100;
        updateMix();
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-mute]').forEach(button => button.addEventListener('click', () => {
        const index = Number(button.dataset.mute);
        muted[index] = !muted[index];
        button.classList.toggle('active', muted[index]);
        updateMix();
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-solo]').forEach(button => button.addEventListener('click', () => {
        const index = Number(button.dataset.solo);
        soloed[index] = !soloed[index];
        button.classList.toggle('active', soloed[index]);
        updateMix();
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-select-track]').forEach(button => button.addEventListener('click', () => selectTrack(Number(button.dataset.selectTrack))));
      studio.querySelectorAll<HTMLButtonElement>('[data-clip]').forEach(button => button.addEventListener('click', () => {
        studio.querySelectorAll('[data-clip]').forEach(clip => clip.classList.remove('selected'));
        button.classList.add('selected');
        selectTrack(Number(button.dataset.track), button.querySelector('span')?.textContent ?? 'CLIP');
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-bar]').forEach(button => button.addEventListener('click', () => {
        position = Number(button.dataset.bar) * 4 * 60 / bpm();
        if (playing) startedAt = performance.now() - position * 1000;
      }));
      studio.querySelectorAll('[data-browser-toggle]').forEach(button => button.addEventListener('click', () => studio.classList.toggle('browser-closed')));
      studio.querySelector('[data-editor-toggle]')?.addEventListener('click', () => studio.classList.toggle('editor-closed'));
      studio.querySelector('[data-snap]')?.addEventListener('click', (event) => {
        const button = event.currentTarget as HTMLButtonElement;
        const on = button.getAttribute('aria-pressed') !== 'true';
        button.setAttribute('aria-pressed', String(on));
        button.classList.toggle('off', !on);
      });
      studio.querySelectorAll<HTMLButtonElement>('[data-view]').forEach(button => button.addEventListener('click', () => {
        const sessionMode = button.dataset.view === 'session';
        studio.querySelector('.arrangement')?.classList.toggle('session-mode', sessionMode);
        studio.querySelectorAll('[data-view]').forEach(item => item.classList.toggle('active', item === button));
        studio.querySelector<HTMLElement>('.arrangement-label span')!.textContent = sessionMode ? 'SESSION' : 'ARRANGEMENT';
      }));
      studio.querySelector('[data-automation]')?.addEventListener('click', (event) => {
        const button = event.currentTarget as HTMLButtonElement;
        const on = button.getAttribute('aria-pressed') !== 'true';
        button.setAttribute('aria-pressed', String(on));
        button.classList.toggle('active', on);
        timeline.classList.toggle('automation-on', on);
      });
      studio.querySelectorAll<HTMLButtonElement>('[data-session-clip]').forEach(button => button.addEventListener('click', () => {
        if (button.classList.contains('empty')) { showToast('Empty clip slot'); return; }
        const track = Number(button.dataset.track);
        studio.querySelectorAll(`[data-session-clip][data-track="${track}"]`).forEach(clip => clip.classList.remove('launched'));
        button.classList.add('launched');
        muted[track] = false;
        studio.querySelector<HTMLButtonElement>(`[data-mute="${track}"]`)?.classList.remove('active');
        updateMix();
        selectTrack(track, button.querySelector('span')?.textContent ?? 'CLIP');
        if (!playing) togglePlay();
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-track-stop]').forEach(button => button.addEventListener('click', () => {
        const track = Number(button.dataset.trackStop);
        studio.querySelectorAll(`[data-session-clip][data-track="${track}"]`).forEach(clip => clip.classList.remove('launched'));
        muted[track] = true;
        studio.querySelector<HTMLButtonElement>(`[data-mute="${track}"]`)?.classList.add('active');
        updateMix();
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-scene]').forEach(button => button.addEventListener('click', () => {
        const scene = Number(button.dataset.scene);
        studio.querySelectorAll<HTMLButtonElement>('[data-session-clip]').forEach((clip, index) => {
          if (Math.floor(index / 4) === scene && !clip.classList.contains('empty')) clip.classList.add('launched');
        });
        showToast(`Scene ${scene + 1} launched`);
        if (!playing) togglePlay();
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-editor-tab]').forEach(button => button.addEventListener('click', () => {
        const device = button.dataset.editorTab === 'device';
        studio.querySelectorAll('[data-editor-tab]').forEach(item => item.classList.toggle('active', item === button));
        studio.querySelector('[data-editor]')?.classList.toggle('device-view', device);
      }));
      studio.querySelectorAll<HTMLButtonElement>('[data-toast]').forEach(button => button.addEventListener('click', () => showToast(button.dataset.toast ?? 'Done')));

      studio.querySelectorAll<HTMLCanvasElement>('[data-wave]').forEach((canvas, canvasIndex) => {
        const context = canvas.getContext('2d');
        if (!context) return;
        const track = Number(canvas.dataset.wave);
        const color = ['#ff6b4a', '#f4ce55', '#67d4ae', '#72a8ff'][track];
        context.strokeStyle = color;
        context.lineWidth = 1.5;
        context.globalAlpha = 0.82;
        context.beginPath();
        for (let x = 0; x < canvas.width; x += 2) {
          const envelope = Math.sin((x / canvas.width) * Math.PI);
          const wave = track === 0
            ? Math.pow(Math.abs(Math.sin(x * 0.17 + canvasIndex)), 8)
            : Math.abs(Math.sin(x * (0.035 + track * 0.012) + canvasIndex) * Math.sin(x * 0.11));
          const height = 4 + wave * envelope * 18;
          context.moveTo(x, 25 - height);
          context.lineTo(x, 25 + height);
        }
        context.stroke();
      });

      document.addEventListener('keydown', event => {
        const target = event.target as HTMLElement;
        if (event.code === 'Space' && !['INPUT', 'TEXTAREA', 'BUTTON'].includes(target.tagName)) {
          event.preventDefault();
          togglePlay();
        }
      });
      selectTrack(2, 'GLASS CHORDS');
      if (window.innerWidth <= 900) studio.classList.add('browser-closed');
      animationId = requestAnimationFrame(animate);
      window.addEventListener('beforeunload', () => { cancelAnimationFrame(animationId); window.clearInterval(schedulerId); audio?.close(); });
    }
  </script>
</Layout>

